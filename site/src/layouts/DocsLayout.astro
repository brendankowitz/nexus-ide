---
import BaseLayout from './BaseLayout.astro';
import NexusMark from '../components/NexusMark.astro';
import { NAV } from '../config/nav';
import type { MarkdownHeading } from 'astro';

interface PagerLink { title: string; href: string; }
interface Props {
  title: string;
  description?: string;
  group: string;
  currentHref: string;
  headings: MarkdownHeading[];
  prev?: PagerLink;
  next?: PagerLink;
}

const { title, description, group, currentHref, headings = [], prev, next } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
const githubHref = 'https://github.com/brendankowitz/nexus-ide';

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<BaseLayout title={`${title} · Nexus IDE Docs`} description={description}>
  <header class="dtop">
    <button class="dham" id="dham" aria-label="Toggle navigation" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <a class="brand" href={homeHref}>
      <NexusMark size={24} gradientId="nxw-top" />
      <span class="word">Nexus</span>
    </a>
    <span class="dpill">docs</span>
    <span class="dspacer"></span>
    <a class="dtoplink" href={homeHref}>Home</a>
    <a class="dtoplink" href={githubHref} aria-label="GitHub repository">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
  </header>

  <div class="dscrim" id="dscrim"></div>

  <div class="dshell">
    <aside class="dside" id="dside">
      <nav class="dnav">
        {NAV.map((g) => (
          <div class="dgroup">
            <p class="dgroup-label">{g.group}</p>
            <ul>
              {g.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={item.href === currentHref ? 'dlink active' : 'dlink'}
                    aria-current={item.href === currentHref ? 'page' : undefined}
                  >{item.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <main class="dmain">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={homeHref}>Docs</a>
        <span class="bsep">/</span>
        <span class="bgroup">{group}</span>
        <span class="bsep">/</span>
        <span class="bcurrent">{title}</span>
      </nav>

      <article class="prose">
        <h1>{title}</h1>
        <slot />
      </article>

      {(prev || next) && (
        <div class="pager">
          {prev ? (
            <a href={prev.href} class="pager-prev">
              <span class="pager-label">← Previous</span>
              <span class="pager-title">{prev.title}</span>
            </a>
          ) : <span class="pager-spacer"></span>}
          {next ? (
            <a href={next.href} class="pager-next">
              <span class="pager-label">Next →</span>
              <span class="pager-title">{next.title}</span>
            </a>
          ) : <span class="pager-spacer"></span>}
        </div>
      )}
    </main>

    <aside class="dtoc">
      {toc.length > 0 && (
        <>
          <p class="dtoc-label">On this page</p>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'toc-sub' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </>
      )}
    </aside>
  </div>
</BaseLayout>

<style is:global>
  .dtop { position: sticky; top: 0; z-index: 100; height: 56px; background: rgba(10,12,15,0.82); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 18px; padding: 0 20px; }
  .dshell { display: grid; grid-template-columns: 264px minmax(0, 1fr) 220px; max-width: 1380px; margin: 0 auto; align-items: start; }
  .dside { position: sticky; top: 56px; height: calc(100vh - 56px); overflow-y: auto; padding: 28px 16px 60px 24px; border-right: 1px solid var(--border); }
  .dmain { min-width: 0; padding: 40px 56px 100px; }
  .prose h1 { font-family: var(--serif); font-size: 40px; font-weight: 600; letter-spacing: -0.015em; line-height: 1.1; margin: 0 0 14px; }
  .prose .lead { font-size: 18px; color: var(--ink-dim); line-height: 1.6; margin: 0 0 36px; }
  .prose h2 { font-size: 24px; font-weight: 600; margin: 48px 0 14px; scroll-margin-top: 76px; }
  .prose h3 { font-size: 18px; font-weight: 600; margin: 32px 0 10px; scroll-margin-top: 76px; }
  .prose p, .prose li { color: #cfd5db; line-height: 1.7; }
  .prose strong { color: var(--ink); font-weight: 600; }
  .prose a { border-bottom: 1px solid rgba(45,212,207,0.3); }
  .prose code { font-family: var(--mono); font-size: 0.86em; background: var(--bg-2); border: 1px solid var(--border); border-radius: 5px; padding: 1px 6px; color: var(--terra-soft); }
  .prose pre { background: #0c0e12; border: 1px solid var(--border-2); border-radius: var(--radius); padding: 16px 18px; overflow-x: auto; margin: 0 0 22px; }
  .prose pre code { background: none; border: 0; padding: 0; color: var(--ink); font-size: 13px; }
  .prose ul, .prose ol { padding-left: 22px; margin: 0 0 22px; }
  .prose li { margin: 4px 0; }
  .prose table { width: 100%; border-collapse: collapse; margin: 0 0 24px; font-size: 14px; }
  .prose th { text-align: left; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); padding: 10px 14px; border-bottom: 1px solid var(--border-2); background: var(--bg-1); }
  .prose td { padding: 11px 14px; border-bottom: 1px solid var(--border); color: var(--ink-dim); }
  .callout { display: grid; grid-template-columns: 26px 1fr; gap: 12px; border-radius: var(--radius); padding: 14px 16px; margin: 0 0 24px; border: 1px solid var(--border-2); background: var(--bg-1); font-size: 14px; }
  .callout.note { border-color: rgba(45,212,207,0.3); }
  .callout.tip { border-color: rgba(72,211,154,0.3); }
  .callout.warn { border-color: rgba(230,193,104,0.3); }
  .keys { margin: 0 0 24px; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .keyrow { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 11px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .keyrow:last-child { border-bottom: 0; }
  .keyrow:nth-child(odd) { background: rgba(255,255,255,0.012); }
  .pager { display: flex; gap: 14px; margin-top: 56px; padding-top: 28px; border-top: 1px solid var(--border); }
  .pager a { flex: 1; border: 1px solid var(--border-2); border-radius: var(--radius); padding: 16px 18px; display: flex; flex-direction: column; gap: 4px; }
  .dtoc { position: sticky; top: 56px; max-height: calc(100vh - 56px); overflow-y: auto; padding: 44px 24px 60px 8px; }
  @media (max-width: 1100px) { .dshell { grid-template-columns: 248px minmax(0,1fr); } .dtoc { display: none; } }
  @media (max-width: 820px) { .dshell { grid-template-columns: 1fr; } .dside { position: fixed; top: 56px; left: 0; bottom: 0; width: 290px; z-index: 90; background: var(--bg); transform: translateX(-100%); transition: transform .22s ease; } }
</style>

<style>
  .dham { display: none; background: none; border: 0; color: var(--ink-dim); cursor: pointer; padding: 4px; }
  .dpill { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: lowercase; color: var(--ink-faint); border: 1px solid var(--border-2); border-radius: 999px; padding: 2px 9px; }
  .dspacer { flex: 1; }
  .dtoplink { display: inline-flex; align-items: center; font-size: 14px; color: var(--ink-dim); }
  .dtoplink:hover { color: var(--ink); }
  .dscrim { display: none; position: fixed; inset: 56px 0 0 0; background: rgba(0,0,0,0.5); z-index: 80; }
  .dscrim.open { display: block; }

  .dnav .dgroup { margin-bottom: 26px; }
  .dgroup-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin: 0 0 8px; padding-left: 12px; }
  .dnav ul { list-style: none; margin: 0; padding: 0; }
  .dlink { display: block; font-size: 14px; color: var(--ink-dim); padding: 6px 12px; border-left: 2px solid transparent; border-radius: 0 6px 6px 0; }
  .dlink:hover { color: var(--ink); background: rgba(255,255,255,0.02); }
  .dlink.active { color: var(--cyan); border-left-color: var(--cyan); background: rgba(45,212,207,0.06); font-weight: 500; }

  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--ink-faint); margin-bottom: 24px; }
  .breadcrumb a { color: var(--ink-faint); }
  .breadcrumb a:hover { color: var(--ink-dim); }
  .bsep { color: var(--ink-ghost); }
  .bgroup { color: var(--ink-faint); }
  .bcurrent { color: var(--ink-dim); }

  .pager-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); }
  .pager-title { color: var(--ink); font-weight: 500; }
  .pager-next { text-align: right; }
  .pager-spacer { flex: 1; }
  .pager :global(a) { text-decoration: none; }
  .pager :global(a:hover) { border-color: #38414c; }

  .dtoc-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin: 0 0 12px; }
  .dtoc ul { list-style: none; margin: 0; padding: 0; }
  .dtoc li { margin: 6px 0; }
  .dtoc li.toc-sub { padding-left: 14px; }
  .dtoc a { font-size: 13px; color: var(--ink-dim); border-bottom: 0; }
  .dtoc a:hover { color: var(--cyan); }

  @media (max-width: 820px) {
    .dham { display: inline-flex; }
    .dside.open { transform: translateX(0); }
  }
</style>

<script>
  const ham = document.getElementById('dham');
  const side = document.getElementById('dside');
  const scrim = document.getElementById('dscrim');
  function close() {
    side?.classList.remove('open');
    scrim?.classList.remove('open');
    ham?.setAttribute('aria-expanded', 'false');
  }
  ham?.addEventListener('click', () => {
    const open = side?.classList.toggle('open');
    scrim?.classList.toggle('open', open);
    ham?.setAttribute('aria-expanded', String(!!open));
  });
  scrim?.addEventListener('click', close);
</script>
