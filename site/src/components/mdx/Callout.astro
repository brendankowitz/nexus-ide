---
interface Props {
  type?: 'note' | 'tip' | 'warn';
}
const { type = 'note' } = Astro.props;
const ICON: Record<string, string> = {
  note: 'i',
  tip: '✓',
  warn: '!',
};
const icon = ICON[type] ?? 'i';
---
<div class={`callout ${type}`}>
  <div class="callout-icon" aria-hidden="true">{icon}</div>
  <div class="callout-body"><slot /></div>
</div>

<style>
  .callout-icon {
    width: 26px;
    height: 22px;
    display: grid;
    place-items: center;
    font-family: var(--mono);
    font-weight: 600;
    font-size: 13px;
    border-radius: 6px;
    background: var(--bg-2);
    border: 1px solid var(--border-2);
    color: var(--ink-dim);
  }
  .callout.note .callout-icon { color: var(--cyan); border-color: rgba(45,212,207,0.4); }
  .callout.tip .callout-icon { color: var(--green); border-color: rgba(72,211,154,0.4); }
  .callout.warn .callout-icon { color: var(--amber); border-color: rgba(230,193,104,0.4); }
  .callout-body :global(p) { margin: 0; }
  .callout-body :global(p + p) { margin-top: 8px; }
</style>
