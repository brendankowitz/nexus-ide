{
  "name": "nexus-ide",
  "version": "0.1.0",
  "description": "Developer Mission Control — project orchestration for AI-assisted workflows",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "electron-vite dev --config electron-vite.config.ts",
    "dev:debug": "electron-vite dev --config electron-vite.config.ts -- --remote-debugging-port=9222",
    "build": "electron-vite build --config electron-vite.config.ts",
    "preview": "electron-vite preview --config electron-vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "electron-builder --win --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "postinstall": "node -e \"if(process.platform==='win32')require('child_process').execSync('patch-package',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@monaco-editor/react": "^4.7.0",
    "@parcel/watcher": "^2.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dugite": "^3.2.2",
    "electron-store": "^11.0.2",
    "immer": "^11.1.8",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "patch-package": "^8.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.1.7",
    "ws": "^8.19.0"
  },
  "overrides": {
    "dompurify": ">=3.3.2"
  }
}
